# ==============================================================================
# SEKRETY - WAŻNE, NIE USUWAJ TEJ SEKCJI
# ==============================================================================
# Ten plik chroni Twoje poświadczenia stooq i inne sekrety przed przypadkowym
# wrzuceniem do repozytorium Git. Gdy commitujesz pliki, Git używa tego pliku
# do odfiltrowania tego, co ma być trzymane tylko lokalnie.

# Pliki konfiguracyjne z poświadczeniami - NIGDY NIE COMMITUJ
application-local.properties
application-prod.properties
application-dev.properties
**/application-local.properties

# Pliki z sekretami w różnych formatach (dla przyszłych rozszerzeń)
*.secret
*.key
*.pem
.env
.env.local

